# Replace these values with your MongoDB Atlas configuration.
# Either set a full connection string or supply individual values:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/studentdb?retryWrites=true&w=majority
MONGO_USER=<username>
MONGO_PASSWORD=<password>
MONGO_CLUSTER=<cluster0.mongodb.net>
MONGO_DB=studentdb
PORT=5000
